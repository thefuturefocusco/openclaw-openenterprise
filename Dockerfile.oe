FROM ghcr.io/thefuturefocusco/openclaw:latest

USER root
RUN mkdir -p /home/node/.openclaw && printf '%s\n' \
  '{' \
  '  "gateway": {' \
  '    "port": 8080,' \
  '    "bind": "lan",' \
  '    "http": {' \
  '      "endpoints": {' \
  '        "chatCompletions": { "enabled": true }' \
  '      }' \
  '    },' \
  '    "controlUi": {' \
  '      "allowedOrigins": ["https://oe-oc-cmme0urv4000.onrender.com"],' \
  '      "dangerouslyAllowHostHeaderOriginFallback": true' \
  '    }' \
  '  },' \
  '  "agents": {' \
  '    "defaults": {' \
  '      "models": {' \
  '        "openrouter/anthropic/claude-opus-4-20250514": {}' \
  '      },' \
  '      "model": {' \
  '        "primary": "openrouter/anthropic/claude-opus-4-20250514"' \
  '      }' \
  '    }' \
  '  }' \
  '}' > /home/node/.openclaw/openclaw.json && chown -R node:node /home/node/.openclaw
USER node

EXPOSE 8080
CMD ["node", "openclaw.mjs", "gateway", "--allow-unconfigured"]
