FROM ghcr.io/thefuturefocusco/openclaw:latest

USER root
RUN mkdir -p /home/node/.openclaw && echo '{"gateway":{"port":8080,"bind":"lan","controlUi":{"allowedOrigins":["https://oe-oc-cmme0urv4000.onrender.com"],"dangerouslyAllowHostHeaderOriginFallback":true}}}' > /home/node/.openclaw/openclaw.json && chown -R node:node /home/node/.openclaw
USER node

EXPOSE 8080
CMD ["node", "openclaw.mjs", "gateway", "--allow-unconfigured"]
